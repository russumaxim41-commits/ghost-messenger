{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease -Pandroid.abiFilters=arm64-v8a"
      },
      "env": {
        "JAVA_OPTS": "-Xmx1536m -XX:+UseSerialGC",
        "GRADLE_OPTS": "-Dorg.gradle.jvmargs=-Xmx1536m -Dorg.gradle.workers.max=1 -Dkotlin.incremental=false",
        "KOTLIN_INCREMENTAL": "false"
      }
    }
  }
}

